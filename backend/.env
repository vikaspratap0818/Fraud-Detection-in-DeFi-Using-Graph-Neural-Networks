# DeFi Fraud Detection Backend - Environment Configuration

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# Model Configuration
MODEL_PATH=../models/gnn_model.pt
DATA_DIR=../data

# Training Configuration
EPOCHS=100
LEARNING_RATE=0.001
HIDDEN_DIM=64
EMBEDDING_DIM=32
NUM_LAYERS=3
DROPOUT=0.3
WEIGHT_DECAY=0.0001

# Data Configuration
DATA_PATH=./data/transaction_dataset.csv
TEST_SIZE=0.2
VAL_SIZE=0.1

# Hardware Configuration
DEVICE=auto  # or 'cuda' or 'cpu'
USE_GPU=true

# Logging
LOG_LEVEL=INFO
LOG_FILE=../logs/fraud_detection.log
